WITH sessions AS (
  SELECT DISTINCT
    DATE(TIMESTAMP_MICROS(event_timestamp)) AS event_date,
    traffic_source.source AS source,
    traffic_source.medium AS medium,
    traffic_source.name AS campaign,
    user_pseudo_id,
    CAST((SELECT ep.value.int_value 
      FROM UNNEST(event_params) AS ep
       WHERE ep.key = 'ga_session_id') AS STRING) AS ga_session_id
  FROM
    `bigquery-public-data.ga4_obfuscated_sample_ecommerce.events_*`
  WHERE
    event_name = 'session_start'
),

funnel AS (
  SELECT
    s.event_date,
    s.source,
    s.medium,
    s.campaign,
    COUNT(*) AS user_sessions_count,
    COUNT(DISTINCT CASE WHEN e.event_name = 'add_to_cart' THEN CONCAT(e.user_pseudo_id, CAST((SELECT ep.value.int_value 
     FROM UNNEST(e.event_params) AS ep
       WHERE ep.key = 'ga_session_id') AS STRING)) END) AS visit_to_cart,
    COUNT(DISTINCT CASE WHEN e.event_name = 'begin_checkout' THEN CONCAT(e.user_pseudo_id, CAST((SELECT ep.value.int_value 
     FROM UNNEST(e.event_params) AS ep
       WHERE ep.key = 'ga_session_id') AS STRING)) END) AS visit_to_checkout,
    COUNT(DISTINCT CASE WHEN e.event_name = 'purchase' THEN CONCAT(e.user_pseudo_id, CAST((SELECT ep.value.int_value 
     FROM UNNEST(e.event_params) AS ep
       WHERE ep.key = 'ga_session_id') AS STRING)) END) AS visit_to_purchase
  FROM
    sessions s
  LEFT JOIN
    `bigquery-public-data.ga4_obfuscated_sample_ecommerce.events_*` e
  ON
    s.user_pseudo_id = e.user_pseudo_id
    AND CAST((SELECT ep.value.int_value 
              FROM UNNEST(e.event_params) AS ep
              WHERE ep.key = 'ga_session_id') AS STRING) = s.ga_session_id
    AND e.event_name IN ('add_to_cart', 'begin_checkout', 'purchase')
  GROUP BY
    s.event_date, s.source, s.medium, s.campaign
)

SELECT *
FROM funnel
ORDER BY event_date, source, medium, campaign;
