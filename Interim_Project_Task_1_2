SELECT
    ad_date,
    SUM(value) AS total_value,
    SUM(spend) AS total_spend,
   
        SUM(value) * 1.0
        / SUM(spend)
     AS romi
FROM (
    SELECT ad_date, spend, value 
    FROM facebook_ads_basic_daily
    WHERE spend > 0

    UNION ALL

    SELECT ad_date, spend, value 
    FROM google_ads_basic_daily
    WHERE spend > 0
) t
GROUP BY ad_date
ORDER BY romi DESC
LIMIT 5;
